#!/bin/bash
# Docker Hub Automated Build Hook for Multi-Architecture
# This file should be placed in hooks/build in your repository

echo "Building multi-architecture images for Docker Hub"

# Enable Docker BuildKit
export DOCKER_BUILDKIT=1

# Build for multiple platforms
docker buildx create --name multiarch --use
docker buildx build \
  --platform linux/amd64,linux/arm64 \
  --tag $IMAGE_NAME \
  --push \
  .