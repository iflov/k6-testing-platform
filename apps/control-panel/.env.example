NODE_ENV=production
PORT=3000

# Prisma - Postgre
DATABASE_URL=postgresql://test_admin:testpassword@postgres:5432/k6_test_history?schema=public

# K6 Runner Service (Kubernetes internal service)
K6_RUNNER_BASE_URL=http://k6-runner:3002

# Mock Server Service  
MOCK_SERVER_URL=http://mock-server:3001

# K6 Dashboard
K6_DASHBOARD_URL=http://k6-runner:5665
NEXT_PUBLIC_K6_DASHBOARD_URL=http://localhost:5665

# Realtime UI tuning
NEXT_PUBLIC_K6_STATUS_POLL_INTERVAL_MS=1000
NEXT_PUBLIC_K6_METRICS_POLL_INTERVAL_MS=1000
NEXT_PUBLIC_K6_PROGRESS_POLL_INTERVAL_MS=1000
NEXT_PUBLIC_K6_METRICS_TIME_RANGE=30s
K6_METRICS_DEFAULT_TIME_RANGE=30s
K6_METRICS_STANDARD_TIME_RANGE=5m

# Influx DB 3.x
INFLUXDB_URL=http://influxdb:8181
INFLUXDB_ORG=k6org
INFLUXDB_BUCKET=k6
INFLUXDB_TOKEN=dev-token-for-testing
