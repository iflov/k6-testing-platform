# Example environment configuration
# Copy this file to .env and update values for your environment

# Environment
NODE_ENV=development

# K6 Configuration Examples:
# ==========================================
# 1. Docker Compose Internal (service-to-service):
#    K6_INFLUXDB_URL=http://influxdb:8086
#
# 2. Docker Compose External Pattern (like EKS):
#    K6_INFLUXDB_URL=http://host.docker.internal:8086
#
# 3. Kubernetes Service:
#    K6_INFLUXDB_URL=http://influxdb-service:8086

# Current Setting (External access pattern)
K6_INFLUXDB_URL=http://host.docker.internal:8086
K6_INFLUXDB_DB=k6

# Mock Server Configuration Examples:
# ==========================================
# 1. Docker Compose Internal:
#    MOCK_SERVER_URL=http://mock-server:3001
#
# 2. Docker Compose External Pattern:
#    MOCK_SERVER_URL=http://host.docker.internal:3001
#
# 3. Kubernetes Service:
#    MOCK_SERVER_URL=http://mock-server-service:3001

# Current Setting (External access pattern)
MOCK_SERVER_URL=http://host.docker.internal:3001

# K6 Runner Configuration Examples:
# ==========================================
# 1. Docker Compose Internal (service-to-service):
#    K6_RUNNER_BASE_URL=http://k6-runner:3002
#
# 2. Docker Compose External Pattern (like EKS):
#    K6_RUNNER_BASE_URL=http://host.docker.internal:3002
#
# 3. Kubernetes Service (cluster internal):
#    K6_RUNNER_BASE_URL=http://k6-runner-service:3002
#
# 4. Kubernetes Ingress/LoadBalancer:
#    K6_RUNNER_BASE_URL=http://k6-runner.example.com

# Current Setting (Docker Compose with external pattern)
# Note: Individual endpoint URLs are automatically derived from K6_RUNNER_BASE_URL
K6_RUNNER_BASE_URL=http://host.docker.internal:3002

# K6 Dashboard
K6_DASHBOARD_URL=http://localhost:5665

# Database Configuration (for Prisma)
# PostgreSQL connection string
DATABASE_URL=postgresql://testuser:testpassword@localhost:5432/k6_test_history?schema=public

# Security Configuration (TODO: Implement in future)
# JWT_SECRET=your-secret-key-here
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
