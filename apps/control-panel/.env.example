# ==========================================
# Control Panel Service Environment Variables
# ==========================================
# Copy this file to .env and update values for your environment

# Service Configuration
NODE_ENV=development
PORT=3000

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://test_admin:testpassword@localhost:5432/k6_test_history?schema=public

# ==========================================
# External Service URLs
# ==========================================
# K6 Runner Service
K6_RUNNER_BASE_URL=http://localhost:3002

# Mock Server Service  
MOCK_SERVER_URL=http://localhost:3001

# K6 Dashboard
K6_DASHBOARD_URL=http://localhost:5665

# ==========================================
# InfluxDB 3.x Configuration
# ==========================================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=k6org
INFLUXDB_BUCKET=k6
INFLUXDB_TOKEN=dev-token-for-testing

# ==========================================
# Kubernetes Detection (Auto-configured)
# ==========================================
# KUBERNETES_SERVICE_HOST is automatically set by Kubernetes