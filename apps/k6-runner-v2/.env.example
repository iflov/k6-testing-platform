# ==========================================
# K6 Runner v2 Service Environment Variables
# ==========================================
# Copy this file to .env and update values for your environment

# Service Configuration
NODE_ENV=development
PORT=3002

# ==========================================
# InfluxDB 3.x Configuration
# ==========================================
# InfluxDB URL Examples:
# - Docker Compose Internal: http://influxdb:8181
# - Docker Compose External: http://host.docker.internal:8181
# - Kubernetes Service: http://influxdb.k6-platform.svc.cluster.local:8181
# - Local Development: http://localhost:8181

INFLUXDB_URL=http://localhost:8181
INFLUXDB_ORG=k6org
INFLUXDB_BUCKET=k6
INFLUXDB_TOKEN=dev-token-for-testing

# ==========================================
# Mock Server Configuration
# ==========================================
# Mock Server URL Examples:
# - Docker Compose Internal: http://mock-server:3001
# - Docker Compose External: http://host.docker.internal:3001
# - Kubernetes Service: http://mock-server.k6-platform.svc.cluster.local:3001
# - Local Development: http://localhost:3001

MOCK_SERVER_URL=http://localhost:3001

# ==========================================
# Control Panel Callback Configuration
# ==========================================
CONTROL_PANEL_URL=http://localhost:3000

# ==========================================
# K6 Dashboard Configuration
# ==========================================
K6_DASHBOARD_HOST=0.0.0.0
K6_DASHBOARD_PORT=5665
K6_DASHBOARD_PERIOD=10s

# ==========================================
# Kubernetes Detection (Auto-configured)
# ==========================================
# KUBERNETES_SERVICE_HOST is automatically set by Kubernetes
# Used to detect if running in Kubernetes environment
