# K6 Runner Configuration Example
# Copy this file to .env and update values for your environment

# Server Configuration
PORT=3002

# Environment
NODE_ENV=production

# Service URLs Configuration:
# ==========================================
# 1. Docker Compose Internal (service-to-service):
#    INFLUXDB_URL=http://influxdb:8086
#    MOCK_SERVER_URL=http://mock-server:3001
#
# 2. Docker Compose External Pattern (like EKS):
#    INFLUXDB_URL=http://host.docker.internal:8086
#    MOCK_SERVER_URL=http://host.docker.internal:3001
#
# 3. Kubernetes Service (cluster internal):
#    INFLUXDB_URL=http://influxdb-service:8086
#    MOCK_SERVER_URL=http://mock-server-service:3001
#
# 4. Kubernetes External (LoadBalancer/Ingress):
#    INFLUXDB_URL=http://influxdb.example.com:8086
#    MOCK_SERVER_URL=http://mock-server.example.com

# Current Settings (External access pattern)
INFLUXDB_URL=http://host.docker.internal:8086
INFLUXDB_USERNAME=k6
INFLUXDB_PASSWORD=your_k6_password_here
MOCK_SERVER_URL=http://host.docker.internal:3001

# K6 Dashboard Configuration
K6_DASHBOARD=true
K6_DASHBOARD_HOST=0.0.0.0
K6_DASHBOARD_PORT=5665
K6_DASHBOARD_PERIOD=1s