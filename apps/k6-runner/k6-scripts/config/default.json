{
  "environments": {
    "local": {
      "targetUrl": "http://localhost:3001",
      "influxdbUrl": "http://localhost:8086"
    },
    "docker": {
      "targetUrl": "http://mock-server:3001",
      "influxdbUrl": "http://influxdb:8086"
    },
    "staging": {
      "targetUrl": "https://staging-api.example.com",
      "influxdbUrl": "http://influxdb:8086"
    },
    "production": {
      "targetUrl": "https://api.example.com",
      "influxdbUrl": "http://influxdb:8086"
    }
  },
  "testProfiles": {
    "smoke": {
      "vus": 1,
      "duration": "1m",
      "description": "Minimal load to verify system works"
    },
    "load": {
      "vus": 10,
      "duration": "5m",
      "description": "Normal expected load"
    },
    "stress": {
      "vus": 50,
      "duration": "10m",
      "description": "Above normal load to find breaking point"
    },
    "spike": {
      "vus": 100,
      "duration": "5m",
      "description": "Sudden traffic spike"
    },
    "soak": {
      "vus": 10,
      "duration": "60m",
      "description": "Extended duration for memory leak detection"
    }
  },
  "thresholds": {
    "default": {
      "http_req_duration": ["p(95)<500"],
      "http_req_failed": ["rate<0.1"],
      "http_reqs": ["rate>10"]
    },
    "strict": {
      "http_req_duration": ["p(95)<200", "p(99)<500"],
      "http_req_failed": ["rate<0.01"],
      "http_reqs": ["rate>50"]
    },
    "relaxed": {
      "http_req_duration": ["p(95)<2000"],
      "http_req_failed": ["rate<0.2"],
      "http_reqs": ["rate>5"]
    }
  }
}