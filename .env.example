# Environment Configuration
NODE_ENV=development

# Service Ports
CONTROL_PANEL_PORT=3000
MOCK_SERVER_PORT=3001
K6_RUNNER_API_PORT=3002
K6_RUNNER_DASHBOARD_PORT=5665
INFLUXDB_PORT=8086

# InfluxDB Configuration
INFLUXDB_DB=k6
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=your_admin_password_here
INFLUXDB_USER=k6
INFLUXDB_USER_PASSWORD=your_k6_password_here

# Service URLs
K6_INFLUXDB_URL=http://influxdb:8086
INFLUXDB_URL=http://influxdb:8086/k6
MOCK_SERVER_URL=http://mock-server:3001

# Mock Server Configuration
ENABLE_DELAY=false
MIN_DELAY=0
MAX_DELAY=100
ENABLE_ERROR_SIMULATION=false
ERROR_RATE=5