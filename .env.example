# ============================================
# K6 Testing Platform - Docker Compose Configuration
# ============================================
# This file contains environment variables for Docker Compose deployment
# Copy this file to .env and update values for your environment
#
# For individual service configurations, see:
# - apps/control-panel/.env.example
# - apps/k6-runner/.env.example  
# - apps/mock-server/.env.example

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
POSTGRES_USER=test_admin
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=k6_test_history
POSTGRES_PORT=5432

# ============================================
# InfluxDB 3.x Configuration
# ============================================
# Authentication (REQUIRED for InfluxDB 3.x)
INFLUXDB_TOKEN=dev-token-for-testing
INFLUXDB_ORG=k6org
INFLUXDB_BUCKET=k6

# Port Configuration (InfluxDB 3.x runs on 8181 internally, mapped to 8086)
INFLUXDB_PORT=8086

# ============================================
# Service Ports (for Docker Compose)
# ============================================
CONTROL_PANEL_PORT=3000
MOCK_SERVER_PORT=3001
K6_RUNNER_PORT=3002

# ============================================
# K6 Dashboard Configuration
# ============================================
K6_DASHBOARD_PORT=5665
K6_DASHBOARD_HOST=0.0.0.0
K6_DASHBOARD_PERIOD=10s

# ============================================
# Node Environment
# ============================================
# Options: development, production, test
NODE_ENV=development

# ============================================
# Network Configuration
# ============================================
# For Docker Compose services to communicate:
# - Use service names for internal communication (e.g., influxdb:8086)
# - Use host.docker.internal for host machine access
# - Use localhost for external access from host

# ============================================
# AWS EKS Deployment (Optional)
# ============================================
# When deploying to AWS EKS, these values will be provided by:
# - AWS Secrets Manager (for tokens and passwords)
# - Kubernetes ConfigMaps (for non-sensitive configuration)
# - External Secrets Operator (for automatic secret synchronization)
#
# Example AWS Secrets Manager configuration:
# AWS_REGION=ap-northeast-2
# AWS_SECRET_NAME=k6-testing-platform/influxdb
#
# The External Secrets Operator will automatically sync secrets from AWS Secrets Manager
# to Kubernetes Secrets, which will then be mounted as environment variables